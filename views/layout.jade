doctype html
html
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title
    link(rel='stylesheet', href='/stylesheets/style.css')
    style.
      body {
        font-family: 'Arial', sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f4f4f4;
      }
      header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        text-align: center;
      }
      nav {
        background: #333;
        padding: 1rem;
        text-align: center;
      }
      nav a {
        color: white;
        text-decoration: none;
        margin: 0 1rem;
        font-size: 1.1rem;
      }
      nav a:hover {
        color: #667eea;
      }
      .container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 2rem;
        background: white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      }
      h1 {
        color: #333;
      }
      footer {
        text-align: center;
        padding: 2rem;
        background: #333;
        color: white;
        margin-top: 2rem;
      }
      /* Estilos Profesionales para el Menú */
      .menu-header, .promos-header {
        text-align: center;
        padding: 3rem 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px 12px 0 0;
        margin: -2rem -2rem 2rem -2rem;
      }
      .menu-header h1, .promos-header h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
      }
      .menu-header p, .promos-header p {
        font-size: 1.2rem;
        opacity: 0.95;
      }
      .menu-filters {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 8px;
      }
      .filter-btn {
        padding: 0.75rem 1.5rem;
        border: 2px solid #667eea;
        background: white;
        color: #667eea;
        border-radius: 25px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
      }
      .filter-btn:hover {
        background: #667eea;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(102, 126, 234, 0.3);
      }
      .filter-btn.active {
        background: #667eea;
        color: white;
      }
      .menu-grid, .promos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .dish-card, .promo-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        position: relative;
      }
      .dish-card:hover, .promo-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15);
      }
      .dish-image, .promo-image {
        height: 200px;
        background-size: cover;
        background-position: center;
        background-color: #f8f9fa;
      }
      .dish-image.placeholder, .promo-image.placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
      .dish-badge, .promo-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
      }
      .promo-discount {
        position: absolute;
        top: 12px;
        left: 12px;
        background: #ff4757;
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: bold;
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }
      .dish-content, .promo-content {
        padding: 1.5rem;
      }
      .dish-name, .promo-title {
        font-size: 1.4rem;
        color: #333;
        margin-bottom: 0.5rem;
        font-weight: 700;
      }
      .dish-description, .promo-description {
        color: #666;
        line-height: 1.6;
        margin-bottom: 1rem;
      }
      .dish-footer, .promo-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 2px solid #f0f0f0;
      }
      .dish-price {
        font-size: 1.8rem;
        font-weight: bold;
        color: #667eea;
      }
      .dish-rating {
        font-size: 1.1rem;
        color: #ffa502;
      }
      .promo-price {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .old-price {
        text-decoration: line-through;
        color: #999;
        font-size: 1rem;
      }
      .new-price {
        font-size: 1.6rem;
        font-weight: bold;
        color: #ff4757;
      }
      .promo-btn, .banner-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .promo-btn:hover, .banner-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(102, 126, 234, 0.4);
      }
      .promo-validity {
        background: #fff3cd;
        color: #856404;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.9rem;
        margin: 1rem 0;
      }
      .promo-card.featured {
        grid-row: span 1;
        border: 3px solid #667eea;
      }
      .promo-banner {
        background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
        padding: 3rem 2rem;
        border-radius: 12px;
        text-align: center;
        margin-top: 3rem;
      }
      .promo-banner h2 {
        font-size: 2rem;
        color: #333;
        margin-bottom: 1rem;
      }
      .promo-banner p {
        font-size: 1.1rem;
        color: #555;
        margin-bottom: 1.5rem;
      }
      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: #f8f9fa;
        border-radius: 12px;
        grid-column: 1 / -1;
      }
      .empty-icon {
        font-size: 5rem;
        margin-bottom: 1rem;
      }
      .empty-state h3 {
        font-size: 1.5rem;
        color: #333;
        margin-bottom: 0.5rem;
      }
      .error-state {
        text-align: center;
        padding: 2rem;
        background: #f8d7da;
        color: #721c24;
        border-radius: 8px;
        font-weight: 600;
      }
      .promos-timeline {
        margin: 2rem 0;
        padding: 2rem;
        background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
        border-radius: 12px;
      }
      .timeline-item {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .timeline-marker {
        font-size: 3rem;
      }
      .timeline-content h3 {
        font-size: 1.5rem;
        color: #333;
        margin-bottom: 0.3rem;
      }
      .timeline-content p {
        color: #666;
        font-size: 1rem;
      }
      @media (max-width: 768px) {
        .menu-header h1, .promos-header h1 {
          font-size: 2rem;
        }
        .menu-grid, .promos-grid {
          grid-template-columns: 1fr;
        }
        .menu-filters {
          flex-direction: column;
        }
        .filter-btn {
          width: 100%;
        }
      }
      /* ========================================
         DISEÑO 3D PROFESIONAL PARA CHEFS
         ======================================== */
      
      /* Hero Section 3D */
      .chefs-hero {
        position: relative;
        text-align: center;
        padding: 4rem 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px 12px 0 0;
        margin: -2rem -2rem 2rem -2rem;
        overflow: hidden;
      }
      .chefs-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
        background-size: 50px 50px;
        animation: moveGrid 20s linear infinite;
        transform: perspective(500px) rotateX(60deg);
      }
      @keyframes moveGrid {
        0% { transform: perspective(500px) rotateX(60deg) translateY(0); }
        100% { transform: perspective(500px) rotateX(60deg) translateY(50px); }
      }
      .hero-content {
        position: relative;
        z-index: 2;
      }
      .chefs-hero h1 {
        font-size: 3rem;
        color: white;
        text-shadow: 0 4px 8px rgba(0,0,0,0.3), 0 0 30px rgba(255,255,255,0.3);
        margin-bottom: 0.5rem;
        animation: glow 3s ease-in-out infinite;
      }
      @keyframes glow {
        0%, 100% { text-shadow: 0 4px 8px rgba(0,0,0,0.3), 0 0 30px rgba(255,255,255,0.3); }
        50% { text-shadow: 0 4px 8px rgba(0,0,0,0.3), 0 0 50px rgba(255,255,255,0.6); }
      }
      .chefs-hero p {
        font-size: 1.3rem;
        color: rgba(255,255,255,0.95);
      }
      .floating-elements {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: hidden;
      }
      .float-element {
        position: absolute;
        font-size: 3rem;
        opacity: 0.2;
        animation: float 6s ease-in-out infinite;
      }
      .float-element:nth-child(1) { top: 10%; left: 10%; animation-delay: 0s; }
      .float-element:nth-child(2) { top: 20%; right: 15%; animation-delay: 2s; }
      .float-element:nth-child(3) { bottom: 15%; left: 20%; animation-delay: 4s; }
      @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-30px) rotate(10deg); }
      }
      
      /* Intro Card */
      .chefs-intro {
        margin-bottom: 2rem;
      }
      .intro-card {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 2rem;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
      }
      .intro-card h2 {
        font-size: 2rem;
        color: white;
        margin-bottom: 0.5rem;
      }
      .intro-card p {
        color: rgba(255,255,255,0.95);
        font-size: 1.1rem;
      }
      
      /* Contenedor 3D Grid */
      .chefs-3d-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 3rem;
        margin-bottom: 3rem;
        perspective: 1000px;
      }
      .chefs-grid {
        animation: slideIn 0.6s ease-out forwards;
        opacity: 0;
      }
      @keyframes slideIn {
        from {
          opacity: 0;
          transform: translateY(50px) rotateY(10deg);
        }
        to {
          opacity: 1;
          transform: translateY(0) rotateY(0);
        }
      }
      
      /* Tarjeta 3D Flip */
      .chef-card-3d {
        width: 100%;
        height: 500px;
        position: relative;
        transform-style: preserve-3d;
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
      }
      .chef-card-3d.active-3d {
        transform: rotateY(180deg) scale(1.05);
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.4);
      }
      .card-inner-3d {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
      }
      
      /* Frentes de la tarjeta */
      .card-front-3d,
      .card-back-3d {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      }
      .card-front-3d {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
      }
      .card-back-3d {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        transform: rotateY(180deg);
        color: white;
      }
      
      /* Imagen del Chef */
      .chef-image-container-3d {
        height: 55%;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
      }
      .chef-img-3d {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }
      .chef-card-3d.active-3d .chef-img-3d {
        transform: scale(1.1);
      }
      .chef-placeholder-3d {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 8rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      }
      .chef-glow-effect {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(102, 126, 234, 0.3) 0%, transparent 70%);
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .chef-card-3d:hover .chef-glow-effect {
        opacity: 1;
      }
      
      /* Badge Destacado */
      .chef-badge-featured-3d {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #ffd700 0%, #ffed4e 100%);
        color: #333;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-weight: bold;
        font-size: 0.9rem;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        z-index: 10;
        animation: pulse 2s infinite;
      }
      
      /* Información Frontal */
      .chef-info-front-3d {
        padding: 1.5rem;
        text-align: center;
      }
      .chef-name-3d {
        font-size: 1.8rem;
        color: #333;
        margin-bottom: 0.3rem;
        font-weight: 700;
      }
      .chef-designation-3d {
        font-size: 1.1rem;
        color: #667eea;
        font-weight: 600;
        margin-bottom: 1rem;
      }
      .chef-divider-3d {
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        margin: 1rem auto;
        border-radius: 3px;
      }
      .chef-abbr-3d {
        font-size: 1rem;
        color: #666;
        font-style: italic;
      }
      
      /* Hint para girar */
      .hover-hint-3d {
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(102, 126, 234, 0.1);
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.85rem;
        color: #667eea;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(102, 126, 234, 0.3);
        transition: all 0.3s ease;
      }
      .chef-card-3d:hover .hover-hint-3d {
        background: rgba(102, 126, 234, 0.2);
        border-color: #667eea;
      }
      
      /* Reverso de la tarjeta */
      .chef-info-back-3d {
        padding: 2rem;
        height: 100%;
        overflow-y: auto;
      }
      .chef-back-title-3d {
        font-size: 1.6rem;
        margin-bottom: 1rem;
        text-align: center;
      }
      .chef-description-3d {
        font-size: 1rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        color: rgba(255,255,255,0.95);
      }
      
      /* Barras de Habilidad */
      .chef-skills-3d {
        margin: 1.5rem 0;
      }
      .skill-bar-3d {
        margin-bottom: 1rem;
      }
      .skill-name-3d {
        display: block;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.9);
        margin-bottom: 0.3rem;
      }
      .skill-progress-3d {
        height: 8px;
        background: rgba(255,255,255,0.2);
        border-radius: 4px;
        overflow: hidden;
        position: relative;
      }
      .skill-progress-3d::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: linear-gradient(90deg, #ffd700 0%, #ffed4e 100%);
        animation: shimmer 2s infinite;
      }
      @keyframes shimmer {
        0% { filter: brightness(1); }
        50% { filter: brightness(1.3); }
        100% { filter: brightness(1); }
      }
      
      /* Botones Sociales */
      .chef-social-3d {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 1.5rem;
      }
      .social-btn-3d {
        background: rgba(255,255,255,0.2);
        border: 2px solid rgba(255,255,255,0.3);
        color: white;
        padding: 0.75rem;
        border-radius: 25px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        backdrop-filter: blur(10px);
      }
      .social-btn-3d:hover {
        background: rgba(255,255,255,0.3);
        border-color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.2);
      }
      
      /* Estadísticas */
      .chefs-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
        padding: 2rem;
        background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
        border-radius: 12px;
      }
      .stat-item {
        text-align: center;
      }
      .stat-number {
        font-size: 3.5rem;
        margin-bottom: 0.5rem;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.2));
      }
      .stat-label {
        font-size: 1rem;
        color: #333;
        font-weight: 600;
      }
      
      /* Estados Vacíos y Error */
      .empty-state-3d {
        text-align: center;
        padding: 4rem 2rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 12px;
        grid-column: 1 / -1;
      }
      .empty-icon-3d {
        font-size: 6rem;
        margin-bottom: 1rem;
        animation: bounce 2s infinite;
      }
      @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
      }
      .empty-state-3d h3 {
        font-size: 1.8rem;
        color: #333;
        margin-bottom: 0.5rem;
      }
      .error-state-3d {
        text-align: center;
        padding: 2rem;
        background: #f8d7da;
        color: #721c24;
        border-radius: 8px;
        font-weight: 600;
      }
      
      /* Responsividad 3D */
      @media (max-width: 768px) {
        .chefs-hero h1 {
          font-size: 2rem;
        }
        .chefs-3d-container {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        .chef-card-3d {
          height: 450px;
        }
        .chef-card-3d.active-3d {
          transform: rotateY(180deg) scale(1);
        }
        .stats-grid {
          grid-template-columns: 1fr;
        }
      }
  body
    header
      h1 Restaurante Delicioso
      p El mejor sabor de la cocina
    nav
      a(href='/') Inicio
      a(href='/menu') Menú
      a(href='/promociones') Promociones
      a(href='/chefs') Chefs
      a(href='/aboutus.html') Nosotros
    .container
      block content
    footer
      p &copy; 2026 Restaurante Delicioso. Todos los derechos reservados.
