#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require('../app');
var debug = require('debug')('restauranteserver:server');
var http = require('http');
var https = require('https');
var fs = require('fs');

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);
app.set('secPort', port + 443);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Listen on provided port, on all network interfaces.
 */

function startServers(startPort) {
  var p = startPort;
  app.set('port', p);
  // app.set('secPort', p + 443); // Deshabilitado temporalmente

  server = http.createServer(app);
  server.on('error', (err) => onError(err, p));
  server.on('listening', onListening);

  server.listen(p, () => {
    console.log('Servidor HTTP escuchando en el puerto', p);
  });

  // HTTPS deshabilitado temporalmente por incompatibilidad con Node 25
  /*
  var options = {
    key: fs.readFileSync(__dirname + '/private.key'),
    cert: fs.readFileSync(__dirname + '/certificate.pem')
  };

  secureServer = https.createServer(options, app);
  secureServer.on('error', (err) => onError(err, p));
  secureServer.on('listening', onListening);
  secureServer.listen(app.get('secPort'), () => {
    console.log('Servidor Seguro escuhando en el puerto', app.get('secPort'));
  });
  */
}

startServers(port);

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error, currentPort) {
  if (error.syscall !== 'listen') {
    throw error;
  }

  var bind = typeof currentPort === 'string'
    ? 'Pipe ' + currentPort
    : 'Port ' + currentPort;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use, intentando con el siguiente puerto...');
      try {
        if (server && server.listening) server.close();
      } catch (e) {}
      try {
        if (secureServer && secureServer.listening) secureServer.close();
      } catch (e) {}
      startServers(currentPort + 1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string'
    ? 'pipe ' + addr
    : 'port ' + addr.port;
  debug('Listening on ' + bind);
}
